# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fullcount

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168

# CORS — comma-separated origins, "*" for development
ALLOWED_ORIGINS=*

# Social Login API Keys
KAKAO_REST_API_KEY=your-kakao-rest-api-key
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
APPLE_SERVICE_ID=kr.fullcount.app

# Mobile OAuth Redirect
MOBILE_REDIRECT_URI=kr.fullcount.app://auth
